<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>List Courses</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
  </head>
  <body>
    <nav class="navbar bg-body-secondary p-3 mb-4">
      <div class="container-fluid">
        <a class="navbar-brand">Course Listing</a>
        <form class="d-flex" method="GET" action="/courses/search" role="search">
          <select class="form-select" name="field" aria-label="Search Field">
            <option value="courseNo">Course No</option>
            <option selected value="courseTitle">Course Title</option>
            <option value="semester">Semester</option>
          </select>
          <input class="form-control me-2" name="svalue" value="" type="search" placeholder="Search value" aria-label="Search"/>
          <button class="btn btn-secondary" type="submit">Search</button>
        </form>
      </div>
    </nav>

    <div class="container">
      <a href="/courses/add" class="btn btn-secondary">Add Course</a>
      <% if(courses.length>0){ %>
      <table class="table table-striped table-bordered">
        <thead>
          <tr>
            <th>Course No</th>
            <th>Course Title</th>
            <th>Credit Hours</th>
            <th>Semester</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
            
            <% courses.forEach(course => { %>
                    <tr>
                        <td><%= course.courseNo %></td>
                        <td><%= course.courseTitle %></td>
                        <td><%= course.creditHrs %></td>
                        <td><%= course.semester %></td>
                        <td><a href="/courses/delete/<%= course.courseID%>" class="btn btn-warning">Delete</a></td>
                    </tr>
            <% });%>
        </tbody>
      </table>
      <% }else{ %>
        <h2 class="text-center">No Matching Records Found</h2>
      <% } %>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
